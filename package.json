{
	"name": "@stepdown/analyzer",
	"version": "0.1.0",
	"private": true,
	"description": "TypeScript AST analyzer that enforces the stepdown rule for function organization",
	"keywords": [
		"ast",
		"code-quality",
		"function-organization",
		"static-analysis",
		"stepdown-rule",
		"typescript"
	],
	"license": "MIT",
	"author": "",
	"repository": {
		"type": "git",
		"url": "https://github.com/graffhyrum/stepdown-rule.git"
	},
	"bin": {
		"stepdown-rule": "./dist/cli.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "bun scripts/build.ts && bun run build:declaration",
		"build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json",
		"postbuild": "bun run --shell bun remove-buildinfo",
		"remove-buildinfo": "rm -rf tsconfig.types.tsbuildinfo",
		"dev": "bun run src/cli.ts",
		"test": "bun test",
		"test:coverage": "AGENT=1 bun test --coverage ",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"fix": "biome check --write .",
		"custom-hooks": "bun run scripts/rule-validator.ts && bun run dist/cli.js analyze",
		"fastvet": "bun run build && bun typecheck && bun fix && bun run custom-hooks  && bun run test:coverage",
		"vet": "bun fastvet"
	},
	"dependencies": {
		"arktype": "^2.2.0",
		"commander": "^14.0.3",
		"glob": "^13.0.6",
		"minimatch": "^10.2.4",
		"picocolors": "^1.1.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@changesets/cli": "^2.30.0",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.5.0"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"peerDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260219.1"
	}
}
